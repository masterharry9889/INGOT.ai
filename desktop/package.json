{
  "name": "brainweb-desktop",
  "version": "1.0.0",
  "description": "BrainWeb.ai Desktop App",
  "author": "Aniket",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.brainweb.desktop",
    "productName": "BrainWeb.ai",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "icon.ico",
      "extraResources": [
        {
          "from": "../backend/dist/brainweb-backend.exe",
          "to": "brainweb-backend.exe"
        },
        {
          "from": "../frontend/out",
          "to": "app"
        }
      ]
    },
    "mac": {
      "target": "dmg",
      "extraResources": [
        {
          "from": "../backend/dist/brainweb-backend",
          "to": "brainweb-backend"
        },
        {
          "from": "../frontend/out",
          "to": "app"
        }
      ]
    },
    "linux": {
      "target": "AppImage",
      "icon": "icon.png",
      "extraResources": [
        {
          "from": "../backend/dist/brainweb-backend",
          "to": "brainweb-backend"
        },
        {
          "from": "../frontend/out",
          "to": "app"
        }
      ]
    }
  },
  "dependencies": {
    "png-to-ico": "^3.0.2"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^26.15.3"
  }
}
